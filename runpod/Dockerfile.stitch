FROM runpod/base:0.4.0-cuda11.8.0

# System packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.stitch.txt .
RUN pip install --no-cache-dir -r requirements.stitch.txt

COPY stitch_handler.py .

CMD ["python", "-u", "stitch_handler.py"]
